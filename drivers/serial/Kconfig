config UART_YTM32
	bool "YTMicro YTM32 UART driver"
	default y
	depends on SERIAL
	depends on HAS_YTMICRO_HAL
	depends on DT_HAS_YTMICRO_YTM32_UART_ENABLED
	select SERIAL_HAS_DRIVER
	# NOTE: polling-only for now; do NOT select SERIAL_SUPPORT_INTERRUPT
	# until irq_tx_enable / irq_rx_enable / irq_callback_set are implemented.
