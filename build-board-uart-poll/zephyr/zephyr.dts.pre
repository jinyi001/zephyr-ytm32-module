/ {
    model = "YTM YTM32 EVB";
    compatible = "ytm,ytm32-evb";

    chosen {
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,console = &uart1;
        zephyr,shell-uart = &uart1;
    };

    leds {
        compatible = "gpio-leds";
        led_red: led_0 {
            gpios = <&gpiod 5 (1 << 0)>;
            label = "Red LED (PTD5)";
        };
        led_green: led_1 {
            gpios = <&gpiod 6 (1 << 0)>;
            label = "Green LED (PTD6)";
        };
    };

    aliases {
        counter = &lptmr0;
        led0 = &led_red;
        led1 = &led_green;
    };
};

&cgu {
    status = "okay";
    core-clock = <80000000>;
    core-divider = <1>;
    fast-bus-divider = <1>;
    slow-bus-divider = <2>;
};

&pinctrl {
    uart1_default: uart1_default {
        group1 {
            pinmux = <((((2) & 0xF) << 28) | (((8) & 0x1F) << 24) | (((2) & 0xF) << 0))>;
            bias-pull-up;
            ytmicro,passive-filter;
        };
        group2 {
            pinmux = <((((2) & 0xF) << 28) | (((9) & 0x1F) << 24) | (((2) & 0xF) << 0))>;
            drive-push-pull;
            drive-strength = "high";
            slew-rate = "fast";
        };
    };

    gpiod_leds: gpiod_leds {
        group1 {
            pinmux = <((((3) & 0xF) << 28) | (((5) & 0x1F) << 24) | (((1) & 0xF) << 0))>,
                     <((((3) & 0xF) << 28) | (((6) & 0x1F) << 24) | (((1) & 0xF) << 0))>;
        };
    };
};

&uart1 {
    status = "okay";
    current-speed = <115200>;
    ytmicro,functional-clock-source = <3U>;
    ytmicro,functional-clock-divider = <1>;
    pinctrl-0 = <&uart1_default>;
    pinctrl-names = "default";
};

&gpiod {
    status = "okay";
};

&lptmr0 {
    status = "okay";
};
