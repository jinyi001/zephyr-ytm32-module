# 8 "C:/Users/JinYi/zephyrproject/zephyr-ytm32-module/dts/arm/ytmicro/ytm32/ytm32b1mc0.dtsi" 2 3 4

/ {
 model = "YTMicro YTM32B1MC0";
 compatible = "ytm,ytm32b1mc0";

 cpus {
  #address-cells = <1>;
  #size-cells = <0>;

  cpu0: cpu@0 {
   device_type = "cpu";
   compatible = "arm,cortex-m33";
   reg = <0>;
   #address-cells = <1>;
   #size-cells = <1>;
  };
 };

 cgu: cgu {
  compatible = "ytmicro,ytm32-cgu";
  #clock-cells = <1>;
  status = "okay";
 };

 pinctrl: pinctrl {
  compatible = "ytmicro,ytm32-pinctrl";
  clocks = <&cgu 2U>,
    <&cgu 3U>,
    <&cgu 4U>,
    <&cgu 5U>,
    <&cgu 6U>,
    <&cgu 1U>;
  status = "okay";
 };

 soc {
  flash0: flash@0 {
   compatible = "soc-nv-flash";
   reg = <0x00000000 0x40000>;
  };

  sram0: memory@20000000 {
   compatible = "mmio-sram";
   reg = <0x20000000 0x8000>;
  };

  uart0: uart@4001b000 {
   compatible = "ytmicro,ytm32-uart";
   reg = <0x4001b000 0x1000>;
   interrupts = <31 0>;
   clocks = <&cgu 7U>;
   ytmicro,functional-clock-source = <3U>;
   ytmicro,functional-clock-divider = <1>;
   status = "disabled";
  };

  uart1: uart@4001c000 {
   compatible = "ytmicro,ytm32-uart";
   reg = <0x4001c000 0x1000>;
   interrupts = <33 0>;
   clocks = <&cgu 8U>;
   ytmicro,functional-clock-source = <3U>;
   ytmicro,functional-clock-divider = <1>;
   status = "disabled";
  };

  lptmr0: lptmr@4005d000 {
   compatible = "ytmicro,ytm32-lptmr";
   reg = <0x4005d000 0x1000>;
   interrupts = <58 0>;
   clocks = <&cgu 24U>;
   ytmicro,functional-clock-source = <4U>;
   ytmicro,functional-clock-divider = <1>;
   status = "disabled";
  };

  gpioa: gpio@40011000 {
   compatible = "ytmicro,ytm32-gpio";
   reg = <0x40011000 0x100>,
         <0x40012000 0x100>;
   reg-names = "gpio", "pctrl";
   interrupts = <59 0>;
   gpio-controller;
   #gpio-cells = <2>;
   ngpios = <32>;
   clocks = <&cgu 1U>;
   status = "disabled";
  };

  gpiob: gpio@40011100 {
   compatible = "ytmicro,ytm32-gpio";
   reg = <0x40011100 0x100>,
         <0x40013000 0x100>;
   reg-names = "gpio", "pctrl";
   interrupts = <60 0>;
   gpio-controller;
   #gpio-cells = <2>;
   ngpios = <32>;
   clocks = <&cgu 1U>;
   status = "disabled";
  };

  gpioc: gpio@40011200 {
   compatible = "ytmicro,ytm32-gpio";
   reg = <0x40011200 0x100>,
         <0x40014000 0x100>;
   reg-names = "gpio", "pctrl";
   interrupts = <61 0>;
   gpio-controller;
   #gpio-cells = <2>;
   ngpios = <32>;
   clocks = <&cgu 1U>;
   status = "disabled";
  };

  gpiod: gpio@40011300 {
   compatible = "ytmicro,ytm32-gpio";
   reg = <0x40011300 0x100>,
         <0x40015000 0x100>;
   reg-names = "gpio", "pctrl";
   interrupts = <62 0>;
   gpio-controller;
   #gpio-cells = <2>;
   ngpios = <32>;
   clocks = <&cgu 1U>;
   status = "disabled";
  };

  gpioe: gpio@40011400 {
   compatible = "ytmicro,ytm32-gpio";
   reg = <0x40011400 0x100>,
         <0x40016000 0x100>;
   reg-names = "gpio", "pctrl";
   interrupts = <63 0>;
   gpio-controller;
   #gpio-cells = <2>;
   ngpios = <32>;
   clocks = <&cgu 1U>;
   status = "disabled";
  };

 };
};

&nvic {
 arm,num-irq-priority-bits = <3>;
};
